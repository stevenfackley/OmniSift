# Environment files
# .env.dev and .env.test are safe to commit (no real secrets)
# .env and .env.prod are gitignored — populate via secrets manager
.env
.env.prod

# Docker secrets — plain-text secret files (never commit)
secrets/*.txt

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/

# OmniSift
infra/db/data/
logs/
temp/
