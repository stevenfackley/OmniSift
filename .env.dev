# ============================================================
# OmniSift — Development Environment
# Used by: docker compose up (local dev)
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=omnisift
POSTGRES_PASSWORD=omnisift_dev
POSTGRES_DB=omnisift

# ── API Keys ─────────────────────────────────────────────────
# Replace with your personal dev keys — do not use prod keys locally
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-
TAVILY_API_KEY=tvly-

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=dev_secret_not_for_production_use_32ch
JWT_ISSUER=https://omnisift.local
JWT_AUDIENCE=omnisift-api

# ── ASP.NET Core ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── Blazor Frontend ──────────────────────────────────────────
API_BASE_URL=http://localhost:5000
