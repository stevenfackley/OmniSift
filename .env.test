# ============================================================
# OmniSift — Test Environment
# Used by: CI pipeline and local test runs
# Integration tests use an in-memory database, so POSTGRES_*
# values here are only needed if running against a real test DB.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=omnisift_test
POSTGRES_PASSWORD=omnisift_test
POSTGRES_DB=omnisift_test

# ── API Keys ─────────────────────────────────────────────────
# Tests mock all external services — these values are placeholders
ANTHROPIC_API_KEY=test-key
OPENAI_API_KEY=test-key
TAVILY_API_KEY=test-key

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=test_secret_not_for_production_use_32ch
JWT_ISSUER=https://omnisift.test
JWT_AUDIENCE=omnisift-api-test

# ── ASP.NET Core ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Testing

# ── Blazor Frontend ──────────────────────────────────────────
API_BASE_URL=http://localhost:5000
