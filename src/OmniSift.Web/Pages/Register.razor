@page "/register"
@inject OmniSiftApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>OmniSift — Create Account</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: calc(100vh - 120px); padding: 2rem;">
    <div style="width: 100%; max-width: 420px;">
        <div class="page-header" style="position: static; border: none; padding: 0; margin-bottom: 1.75rem; background: transparent; backdrop-filter: none;">
            <span class="kicker">Account</span>
            <h1>Create Account</h1>
        </div>

        @if (_success)
        {
            <div class="alert alert-success" style="margin-bottom: 1rem;">
                Account created. <a href="/login">Sign in →</a>
            </div>
        }
        else
        {
            <div class="card">
                <div class="form-group">
                    <label class="form-label" for="tenant-name">Organisation name</label>
                    <input id="tenant-name" type="text" class="form-input"
                           @bind="_tenantName" @bind:event="oninput"
                           placeholder="Acme Investigations"
                           disabled="@_busy" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="email">Email</label>
                    <input id="email" type="email" class="form-input"
                           @bind="_email" @bind:event="oninput"
                           placeholder="you@example.com"
                           disabled="@_busy" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input id="password" type="password" class="form-input"
                           @bind="_password" @bind:event="oninput"
                           placeholder="8+ characters"
                           disabled="@_busy" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-error">@_error</div>
                }

                <button class="btn btn-primary" style="width: 100%;"
                        @onclick="DoRegister"
                        disabled="@(_busy || !CanSubmit)">
                    @if (_busy)
                    {
                        <span class="spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>
                        <span>Creating account…</span>
                    }
                    else
                    {
                        <span>Create account</span>
                    }
                </button>

                <p style="margin-top: 1.25rem; font-size: 0.88rem; color: var(--text-muted); text-align: center;">
                    Already have an account? <a href="/login">Sign in →</a>
                </p>
            </div>
        }
    </div>
</div>

@code {
    private string _tenantName = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private bool _busy;
    private bool _success;
    private string? _error;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(_tenantName) &&
        !string.IsNullOrWhiteSpace(_email) &&
        _password.Length >= 8;

    private async Task DoRegister()
    {
        if (!CanSubmit || _busy)
            return;

        _busy = true;
        _error = null;

        try
        {
            var req = new OmniSift.Shared.DTOs.RegisterRequest
            {
                Email = _email.Trim(),
                Password = _password,
                TenantName = _tenantName.Trim()
            };

            var err = await Api.RegisterAsync(req).ConfigureAwait(false);
            if (err is not null)
            {
                _error = err;
                return;
            }

            _success = true;
        }
        catch (Exception ex)
        {
            _error = $"Registration failed: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
