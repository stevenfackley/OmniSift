@page "/agent"

<PageTitle>OmniSift — Research Agent</PageTitle>

<div class="page-header">
    <span class="kicker">Research Agent</span>
    <h1>Ask anything. Get it sourced.</h1>
</div>

<div class="card" style="margin-top: 1.5rem;">
    <div class="chat-container">
        <div class="chat-messages" @ref="_messagesDiv">
            @if (_messages.Count == 0)
            {
                <div class="empty-state">
                    <span class="eyebrow">▸ ready</span>
                    <p style="font-family: var(--display); font-size: 1.5rem; color: var(--text);">
                        Search your documents, the web, and the archive.
                    </p>
                    <p class="hint">Try: “What addresses did John Smith live at?” or “Find information about…”</p>
                    <ul class="source-tags">
                        <li>&#9656; PDF</li>
                        <li>&#9656; SMS</li>
                        <li>&#9656; WEB</li>
                        <li>&#9656; ARCHIVE</li>
                    </ul>
                </div>
            }

            @foreach (var msg in _messages)
            {
                <div class="chat-message @msg.Role">
                    @if (msg.Role == "assistant")
                    {
                        <div class="chat-md">@((MarkupString)_md.Render(msg.Content))</div>
                    }
                    else
                    {
                        <div>@((MarkupString)EscapeHtml(msg.Content))</div>
                    }

                    @if (msg.Sources?.Count > 0)
                    {
                        <div class="citations">
                            <div class="citations-label">Sources</div>
                            <ul class="citations-list">
                                @foreach (var src in msg.Sources)
                                {
                                    <li class="citation-card">
                                        <span class="citation-type">@src.Type</span>
                                        @if (!string.IsNullOrWhiteSpace(src.Title))
                                        {
                                            <span class="citation-title">
                                                @if (!string.IsNullOrWhiteSpace(src.Url))
                                                {
                                                    <a href="@src.Url" target="_blank" rel="noopener noreferrer">@src.Title</a>
                                                }
                                                else
                                                {
                                                    @src.Title
                                                }
                                            </span>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(src.Url))
                                        {
                                            <a class="citation-url" href="@src.Url" target="_blank" rel="noopener noreferrer">@src.Url</a>
                                        }
                                        @if (src.RelevanceScore.HasValue)
                                        {
                                            <span class="citation-score">@(src.RelevanceScore.Value.ToString("F2"))</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    @if (msg.PluginsUsed?.Count > 0)
                    {
                        <div class="chat-plugins">
                            @foreach (var plugin in msg.PluginsUsed)
                            {
                                <span class="plugin-tag">@plugin</span>
                            }
                        </div>
                    }
                    @if (msg.DurationMs > 0)
                    {
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">
                            ⏱ @(msg.DurationMs)ms
                        </div>
                    }
                </div>
            }

            @if (_isLoading)
            {
                <div class="chat-message assistant">
                    <div class="spinner" style="width: 24px; height: 24px; border-width: 3px;"></div>
                    <span style="margin-left: 0.5rem; color: var(--text-muted);">Thinking...</span>
                </div>
            }
        </div>

        <div class="chat-input-area">
            <textarea class="form-textarea"
                      @bind="_currentQuery"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      placeholder="Ask a research question..."
                      disabled="@_isLoading"></textarea>
            <button class="btn btn-primary" @onclick="SendQuery" disabled="@(_isLoading || string.IsNullOrWhiteSpace(_currentQuery))">
                Send
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-error" style="margin-top: 1rem;">@_error</div>
}

@code {
    [Inject] private OmniSiftApiClient Api { get; set; } = default!;
    [Inject] private MarkdownService _md { get; set; } = default!;

    private ElementReference _messagesDiv;
    private string _currentQuery = string.Empty;
    private bool _isLoading;
    private string? _error;
    private readonly List<ChatMessage> _messages = [];
    private readonly List<ConversationMessage> _conversationHistory = [];

    private async Task SendQuery()
    {
        if (string.IsNullOrWhiteSpace(_currentQuery) || _isLoading)
            return;

        var query = _currentQuery.Trim();
        _currentQuery = string.Empty;
        _error = null;

        // Add user message
        _messages.Add(new ChatMessage("user", query));
        _isLoading = true;
        StateHasChanged();

        try
        {
            var request = new AgentQueryRequest
            {
                Query = query,
                ConversationHistory = _conversationHistory.Count > 0
                    ? _conversationHistory.TakeLast(10).ToList()
                    : null
            };

            var response = await Api.QueryAgentAsync(request).ConfigureAwait(false);

            // Add assistant message
            _messages.Add(new ChatMessage("assistant", response.Response)
            {
                PluginsUsed = response.PluginsUsed,
                DurationMs = response.DurationMs,
                Sources = response.Sources
            });

            // Update conversation history
            _conversationHistory.Add(new ConversationMessage { Role = "user", Content = query });
            _conversationHistory.Add(new ConversationMessage { Role = "assistant", Content = response.Response });
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendQuery().ConfigureAwait(false);
        }
    }

    /// <summary>HTML-escapes user text so it is safe to embed as MarkupString.</summary>
    private static string EscapeHtml(string content) =>
        content
            .Replace("&", "&amp;")
            .Replace("<", "&lt;")
            .Replace(">", "&gt;")
            .Replace("\n", "<br/>");

    private sealed class ChatMessage
    {
        public string Role { get; }
        public string Content { get; }
        public List<string>? PluginsUsed { get; init; }
        public List<SourceCitation>? Sources { get; init; }
        public int DurationMs { get; init; }

        public ChatMessage(string role, string content)
        {
            Role = role;
            Content = content;
        }
    }
}
