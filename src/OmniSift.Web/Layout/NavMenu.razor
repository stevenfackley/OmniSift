@inject AuthStateService Auth
@inject NavigationManager Nav
@implements IDisposable

<nav class="sidebar">
    <div class="sidebar-brand">
        <span class="node-mark">&gt;o)</span> Omni<span>Sift</span>
    </div>

    <div class="sidebar-nav">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <span class="nav-icon">⌂</span>
            Home
        </NavLink>

        <NavLink class="nav-link" href="agent">
            <span class="nav-icon">◆</span>
            Research Agent
        </NavLink>

        <NavLink class="nav-link" href="datasources">
            <span class="nav-icon">▤</span>
            Data Sources
        </NavLink>

        <NavLink class="nav-link" href="entities">
            <span class="nav-icon">⬡</span>
            Entities
        </NavLink>
    </div>

    <div style="padding: 1rem 1.5rem; border-top: 1px solid var(--border);">
        @if (Auth.IsAuthenticated)
        {
            <button class="btn btn-outline btn-sm" style="width: 100%;" @onclick="SignOut">
                Sign out
            </button>
        }
        else
        {
            <a href="/login" class="btn btn-outline btn-sm" style="width: 100%; justify-content: center;">
                Sign in
            </a>
        }
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        Auth.OnAuthChanged += HandleAuthChanged;
    }

    private void HandleAuthChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SignOut()
    {
        await Auth.SignOutAsync().ConfigureAwait(false);
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        Auth.OnAuthChanged -= HandleAuthChanged;
    }
}
