# ============================================================
# OmniSift — Environment Variables Template
# Copy this file to .env.dev, .env.test, or .env.prod and fill in values.
# Never commit .env or .env.prod — they contain real secrets.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=omnisift
POSTGRES_PASSWORD=changeme
POSTGRES_DB=omnisift

# ── API Keys ─────────────────────────────────────────────────
# Anthropic — used for Claude (AI agent / chat completions)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used for text-embedding-3-large
OPENAI_API_KEY=sk-...

# Tavily — used for web search plugin
TAVILY_API_KEY=tvly-...

# ── JWT ──────────────────────────────────────────────────────
# Secret must be at least 32 characters
JWT_SECRET=changeme_at_least_32_characters_long
JWT_ISSUER=https://omnisift.local
JWT_AUDIENCE=omnisift-api

# ── ASP.NET Core ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── Blazor Frontend ──────────────────────────────────────────
# URL of the backend API as seen by the browser
API_BASE_URL=http://localhost:5000
